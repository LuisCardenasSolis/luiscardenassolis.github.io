---

<section id="experience" class="border-b border-dim px-6 md:px-8 py-14 max-w-6xl mx-auto">
  <div class="flex items-center gap-4 mb-10">
    <span class="font-mono text-[11px] text-accent opacity-60">01</span>
    <span class="font-mono text-[11px] uppercase tracking-widest text-muted">Experiencia laboral</span>
  </div>

  <div class="divide-y divide-[rgba(100,120,255,0.15)]">
    {
      jobs.map(({ date, company, role, desc }) => (
        <div class="grid grid-cols-1 md:grid-cols-[160px_1fr] gap-1 md:gap-8 py-6 hover:bg-accent/3 transition-colors">
          <p class="font-mono text-[11px] text-muted md:pt-0.5">{date}</p>
          <div>
            <p class="mb-1 font-mono text-[11px] uppercase tracking-widest font-semibold text-accent2">
              {company}
            </p>
            <p class="mb-1.5 text-[1rem] font-bold text-[#e8e8f0]">{role}</p>
            <p class="text-[0.85rem] leading-relaxed text-muted">{desc}</p>
          </div>
        </div>
      ))
    }
  </div>
</section>
